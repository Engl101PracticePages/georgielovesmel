function seattleParts(date = new Date()) {
  const parts = new Intl.DateTimeFormat("en-US", { timeZone: TZ, weekday:"long", hour:"numeric", minute:"2-digit", hour12:false }).formatToParts(date);
  const get = t => parts.find(p => p.type === t)?.value;
  return { weekday: get("weekday"), hour: Number(get("hour")), minute: Number(get("minute")) };
}
function todayLine(place, date = new Date()) {
  const day = seattleParts(date).weekday;
  return (place.weekday_text || []).find(line => line.startsWith(day + ":")) || "";
}
function cleanHoursText(text) { return (text || "").replace(/[\u2009\u202f]/g, " ").replace(/\s+/g, " ").trim(); }
function displayTodayHours(place) {
  const line = cleanHoursText(todayLine(place));
  if (!line) return "Hours not listed";
  return line.replace(/^[A-Za-z]+:\s*/, "");
}
function parseTime(raw, fallbackMeridiem, endHourForInference) {
  raw = cleanHoursText(raw);
  const m = raw.match(/^(\d{1,2})(?::(\d{2}))?\s*(AM|PM)?$/i);
  if (!m) return null;
  let h = Number(m[1]), min = Number(m[2] || 0), mer = (m[3] || fallbackMeridiem || "").toUpperCase();
  if (!mer) mer = "PM";
  if (mer === "PM" && h !== 12) h += 12;
  if (mer === "AM" && h === 12) h = 0;
  return h * 60 + min;
}
function intervalsForToday(place) {
  const text = displayTodayHours(place);
  if (!text || /closed/i.test(text) || /not listed/i.test(text)) return [];
  return text.split(",").map(part => cleanHoursText(part)).map(range => {
    const pieces = range.split(/\s*[–-]\s*/);
    if (pieces.length < 2) return null;
    const endMer = pieces[1].match(/\b(AM|PM)\b/i)?.[1]?.toUpperCase();
    let startMer = pieces[0].match(/\b(AM|PM)\b/i)?.[1]?.toUpperCase() || endMer;
    let start = parseTime(pieces[0], startMer);
    let end = parseTime(pieces[1], endMer);
    if (start == null || end == null) return null;
    if (end <= start) end += 24 * 60;
    return [start, end];
  }).filter(Boolean);
}
function calculatedStatus(place) {
  if (place.business_status === "CLOSED_PERMANENTLY") return { key:"bad", label:"Permanently closed" };
  const intervals = intervalsForToday(place);
  if (!intervals.length) return { key:"closed", label: displayTodayHours(place) === "Closed" ? "Closed today" : "Hours not listed" };
  const now = seattleParts();
  const minutes = now.hour * 60 + now.minute;
  const open = intervals.some(([s,e]) => minutes >= s && minutes < e);
  return { key: open ? "open" : "closed", label: open ? "Open now" : "Closed now" };
}
function placeText(place) { return [place.name, place.notes, place.address, place.category, place.speed, place.price].join(" ").toLowerCase(); }
function isLimitedSchedulePlace(place) {
  return /farmers market/i.test(place.name || "");
}
function shouldHideByDefault(place) {
  const status = calculatedStatus(place);
  if (place.business_status === "CLOSED_PERMANENTLY" && state.status !== "closedPermanent") return true;
  if (isLimitedSchedulePlace(place) && status.key !== "open" && state.status !== "closedPermanent") return true;
  return false;
}
function matches(place) {
  const status = calculatedStatus(place);
  if (shouldHideByDefault(place)) return false;
  if (state.favoritesOnly && !favorites.includes(place.name)) return false;
  if (state.search && !placeText(place).includes(state.search.toLowerCase())) return false;
  if (state.category !== "all" && place.category !== state.category) return false;
  if (state.speed !== "all" && place.speed !== state.speed) return false;
  if (state.price !== "all" && place.price !== state.price) return false;
  if (state.status === "open" && status.key !== "open") return false;
  if (state.status === "hours" && !(place.weekday_text || []).length) return false;
  if (state.status === "closedPermanent" && place.business_status !== "CLOSED_PERMANENTLY") return false;
  return true;
}
function card(place) {
  const status = calculatedStatus(place); const today = displayTodayHours(place); const isFav = favorites.includes(place.name);
  const hours = (place.weekday_text || []).map(line => `<li class="${line === todayLine(place) ? "today-line" : ""}">${cleanHoursText(line)}</li>`).join("") || "<li>Hours not listed</li>";
  return `<article class="card ${place.business_status === "CLOSED_PERMANENTLY" ? "closed-permanent" : ""}">
    <div class="card-head"><div><h3>${place.name}</h3><div class="chips"><span class="chip">${place.category}</span><span class="chip">${place.speed}</span><span class="chip">${place.price || "?"}</span><span class="chip status ${status.key}">${status.label}</span></div></div>
    <button class="heart ${isFav ? "active" : ""}" type="button" aria-label="Toggle favorite for ${place.name}" data-fav="${place.name}">${isFav ? "♥" : "♡"}</button></div>
    <p class="notes">${place.notes || ""}</p>
    <div class="today"><small>Today’s posted hours</small><b>${today}</b></div>
    <p class="address">${place.address || ""}</p>
    <details><summary>Weekly hours</summary><ul class="hours-list">${hours}</ul></details>
    <div class="card-actions">${place.url ? `<a href="${place.url}" target="_blank" rel="noopener">Map</a>` : ""}${place.website ? `<a href="${place.website}" target="_blank" rel="noopener">Website</a>` : ""}${place.phone ? `<a href="tel:${place.phone}">Call</a>` : ""}</div>
  </article>`;
}
function filteredPlaces() { return PLACES.filter(matches); }
function render() {
  const list = filteredPlaces();
  els.grid.innerHTML = list.map(card).join("");
  els.empty.style.display = list.length ? "none" : "block";
  els.total.textContent = PLACES.length;
  els.open.textContent = PLACES.filter(p => calculatedStatus(p).key === "open").length;
  els.shown.textContent = list.length;
  els.favOnly.textContent = state.favoritesOnly ? "All places" : "Favorites only";
  els.grid.querySelectorAll("[data-fav]").forEach(btn => btn.addEventListener("click", () => toggleFavorite(btn.dataset.fav)));
}
function toggleFavorite(name) {
  favorites = favorites.includes(name) ? favorites.filter(n => n !== name) : [...favorites, name];
  localStorage.setItem("foodListFavorites", JSON.stringify(favorites)); render();
}
function choose() {
  const list = filteredPlaces().filter(p => {
    const status = calculatedStatus(p);
    return p.business_status !== "CLOSED_PERMANENTLY" && !shouldHideByDefault(p) && status.key === "open";
  });
  if (!list.length) {
    els.pickName.textContent = "Nothing open matches this";
    els.pickMeta.textContent = "Try clearing a filter, changing the price or pace, or checking the full list.";
    els.pickActions.innerHTML = "";
    return;
  }
  const p = list[Math.floor(Math.random() * list.length)]; const status = calculatedStatus(p);
  els.pickName.textContent = p.name;
  els.pickMeta.textContent = `${p.notes} Today: ${displayTodayHours(p)}. ${status.label}.`;
  els.pickActions.innerHTML = `${p.url ? `<a href="${p.url}" target="_blank" rel="noopener">Open map</a>` : ""}${p.website ? `<a href="${p.website}" target="_blank" rel="noopener">Website</a>` : ""}`;
}
function resetFilters() {
  Object.assign(state, {search:"", category:"all", speed:"all", price:"all", status:"all", favoritesOnly:false});
  els.search.value=""; els.category.value="all"; els.speed.value="all"; els.price.value="all"; els.status.value="all"; render();
}
["search","category","speed","price","status"].forEach(key => els[key].addEventListener(key === "search" ? "input" : "change", e => { state[key] = e.target.value; render(); }));
els.reset.addEventListener("click", resetFilters);
els.surprise.addEventListener("click", choose);
els.openOnly.addEventListener("click", () => { state.status="open"; els.status.value="open"; render(); document.getElementById("places").scrollIntoView({behavior:"smooth"}); });
els.favOnly.addEventListener("click", () => { state.favoritesOnly = !state.favoritesOnly; render(); });
function tick() { els.clock.textContent = new Intl.DateTimeFormat("en-US", { timeZone: TZ, hour:"numeric", minute:"2-digit" }).format(new Date()); }
tick(); setInterval(() => { tick(); render(); }, 60000); render();
</script>
</body>
</html>
